# Slack App credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: Socket Mode token (for local dev without ngrok)
# Generate at api.slack.com under App-Level Tokens with connections:write scope
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key

# Service Graph API URL (run packages/service-graph first)
SERVICE_GRAPH_URL=http://localhost:3001

# Port for the Bolt HTTP receiver
PORT=3000
